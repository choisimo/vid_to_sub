.coverage
.coverage.*
coverage.xml
htmlcov/
build/
dist/
site/
*.egg-info/
pip-wheel-metadata/

# Local environment files
.env
.env.*
!.env.example
.python-version

# SQLite database (user data, not version-controlled)
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# TUI/runtime state
.textual/

# Editor and OS metadata
.idea/
.vscode/
